  "keyFeatures": [
    "17 MCP tools for Windows automation (UI, system, file operations)",
    "Works with any LLM without requiring vision models",
    "DOM mode for browser automation",
    "Local and remote (VM) deployment modes",
    "Multi-display support with coordinate mapping",
    "Real-time UI element detection via accessibility tree",
    "PowerShell integration for system commands",
    "Clipboard, process, and registry management"
  ],
  "publicApiSurface": [
    "App - Launch/resize/switch applications",
    "Shell/PowerShell - Execute PowerShell commands",
    "FileSystem - Read/write/copy/move/delete/search files",
    "Snapshot - Capture desktop state with screenshots",
    "Click - Mouse clicks at coordinates or UI elements",
    "Type - Type text into UI elements",
    "Scroll - Scroll vertically or horizontally",
    "Move - Move mouse or drag-and-drop",
    "Shortcut - Execute keyboard shortcuts",
    "Wait - Pause execution",
    "Scrape - Fetch web page content",
    "MultiSelect - Select multiple items",
    "MultiEdit - Edit multiple fields",
    "Clipboard - Get/set clipboard content",
    "Process - List/kill processes",
    "Notification - Send Windows toast notifications",
    "Registry - Read/write/delete registry keys"
  ]
